# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB connection URI (e.g. mongodb://localhost:27017/esummit26)
MONGODB_URI=

# Authentication Secrets
JWT_SECRET=supersecretjwtkeychangeitinproduction
JWT_EXPIRES_IN=7d

# Payment Configuration (UPI QR codes)
# The virtual payment address (VPA) / UPI ID where the funds should go
UPI_VPA=merchant@upi
# Optional: multiple UPI IDs for round-robin QR generation
UPI_VPAS=merchant1@upi,merchant2@upi,merchant3@upi
UPI_MERCHANT_NAME=E-Summit 26 IIT Roorkee
# Optional currency defaults to INR
UPI_CURRENCY=INR

# Notification Provider Settings
# SMTP Settings (Nodemailer config)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@esummit.in


ADMIN_KEY=adminkey
